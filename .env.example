# SmartCart AI Backend — Environment Configuration
# Copy this file to .env and fill in your values.

# App
DEBUG=false

# Security — leave empty for open access (development only)
# Separate multiple keys with commas: API_KEYS=key1,key2
API_KEYS=

# LLM Provider: "openai" or "groq"
LLM_PROVIDER=openai
OPENAI_API_KEY=
GROQ_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama3-8b-8192
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Data
MOCK_DATA_ENABLED=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/smartcart
DB_SCHEMA_AUTO_CREATE=true
DB_ECHO=false

# Scraper + fallback behavior
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_MINUTES=180
SCRAPER_BLINKIT_URL=
API_FALLBACK_ENABLED=true
API_FALLBACK_MAX_RETRIES=3
API_FALLBACK_BACKOFF_SECONDS=0.5
EXTERNAL_PRODUCT_API_URL=
